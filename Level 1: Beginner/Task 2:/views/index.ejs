<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page-shell">
      <section class="form-layout">
        <header class="hero-card title-card">
          <div
            class="title-bar"
            style="background: linear-gradient(90deg, #673ab7, #8e63db);"
          ></div>
          <p class="eyebrow">Cognifyz Talent Acquisition</p>
          <h1>Internship Application Form</h1>
          <p class="intro">
            Thank you for your interest in joining Cognifyz. Please complete
            this application form with accurate academic and professional
            details so our hiring team can review your profile.
          </p>
          <div class="form-meta">
            <span>Candidate information</span>
            <span>Hiring team review</span>
            <span>Applications received: <%= storageCount %></span>
          </div>
        </header>

        <section
          class="hero-card info-panel"
          style="margin-bottom: 16px; border-left: 4px solid #673ab7;"
        >
          <div>
            <strong>Application guidance:</strong>
            please select the role and specialization that best match your
            background before submitting your application.
          </div>
          <div
            id="trackPreview"
            class="status-pill"
            style="background: #ede7f6; color: #5b34a3;"
          >
            Preferred track: Awaiting selection
          </div>
        </section>

        <% if (errors.length > 0) { %>
          <section class="alert-box" role="alert">
            <h2>Please fix the following:</h2>
            <ul>
              <% errors.forEach((error) => { %>
                <li><%= error %></li>
              <% }) %>
            </ul>
          </section>
        <% } %>

        <section
          id="clientStatus"
          class="hero-card client-status"
          style="display: none; margin-bottom: 16px;"
          aria-live="polite"
        ></section>

        <form
          action="/submit"
          method="POST"
          class="user-form"
          novalidate
          onsubmit="return validateApplicationForm(this);"
        >
          <section class="question-card">
            <div class="split-grid">
              <div class="field-group">
                <label for="fullName">
                  Full Name <span class="required-star">*</span>
                </label>
                <input
                  type="text"
                  id="fullName"
                  name="fullName"
                  placeholder="Your full name"
                  value="<%= formData.fullName %>"
                  oninput="clearClientError('fullName')"
                  style="<%= fieldErrors.fullName ? 'border-color: #b3261e; background-color: #fff8f8;' : '' %>"
                />
                <small class="inline-error" id="fullNameError"><%= fieldErrors.fullName || "" %></small>
              </div>

              <div class="field-group">
                <label for="email">
                  Email Address <span class="required-star">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="name@example.com"
                  value="<%= formData.email %>"
                  oninput="clearClientError('email')"
                  style="<%= fieldErrors.email ? 'border-color: #b3261e; background-color: #fff8f8;' : '' %>"
                />
                <small class="inline-error" id="emailError"><%= fieldErrors.email || "" %></small>
              </div>
            </div>
          </section>

          <section class="question-card">
            <div class="split-grid">
              <div class="field-group">
                <label for="phone">
                  Contact Number <span class="required-star">*</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+91 98765 43210"
                  value="<%= formData.phone %>"
                  oninput="clearClientError('phone')"
                  style="<%= fieldErrors.phone ? 'border-color: #b3261e; background-color: #fff8f8;' : '' %>"
                />
                <small class="inline-error" id="phoneError"><%= fieldErrors.phone || "" %></small>
              </div>

              <div class="field-group">
                <label for="availability">
                  Availability Date <span class="required-star">*</span>
                </label>
                <input
                  type="date"
                  id="availability"
                  name="availability"
                  value="<%= formData.availability %>"
                  onchange="clearClientError('availability')"
                  style="<%= fieldErrors.availability ? 'border-color: #b3261e; background-color: #fff8f8;' : '' %>"
                />
                <small class="inline-error" id="availabilityError"><%= fieldErrors.availability || "" %></small>
              </div>
            </div>
          </section>

          <section class="question-card">
            <div class="split-grid">
              <div class="field-group">
                <label for="role">
                  Current Role <span class="required-star">*</span>
                </label>
                <select
                  id="role"
                  name="role"
                  onchange="updatePortfolioHint(this.value); clearClientError('role');"
                  style="<%= fieldErrors.role ? 'border-color: #b3261e; background-color: #fff8f8;' : '' %>"
                >
                  <option value="">Choose one</option>
                  <% roleOptions.forEach((role) => { %>
                    <option value="<%= role %>" <%= formData.role === role ? "selected" : "" %>>
                      <%= role %>
                    </option>
                  <% }) %>
                </select>
                <small class="inline-error" id="roleError"><%= fieldErrors.role || "" %></small>
              </div>

              <div class="field-group">
                <label for="track">
                  Preferred Track <span class="required-star">*</span>
                </label>
                <select
                  id="track"
                  name="track"
                  onchange="updateTrackPreview(this.value); clearClientError('track');"
                  style="<%= fieldErrors.track ? 'border-color: #b3261e; background-color: #fff8f8;' : '' %>"
                >
                  <option value="">Select a specialization</option>
                  <% trackOptions.forEach((track) => { %>
                    <option value="<%= track %>" <%= formData.track === track ? "selected" : "" %>>
                      <%= track %>
                    </option>
                  <% }) %>
                </select>
                <small class="inline-error" id="trackError"><%= fieldErrors.track || "" %></small>
              </div>
            </div>
          </section>

          <section class="question-card">
            <div class="field-group">
              <label>
                Preferred Work Mode <span class="required-star">*</span>
              </label>
              <div
                id="workModeGroup"
                class="option-grid"
                style="<%= fieldErrors.workMode ? 'border: 1px solid #f6aea9; border-radius: 10px; padding: 10px;' : '' %>"
              >
                <% workModeOptions.forEach((mode) => { %>
                  <label class="option-card">
                    <input
                      type="radio"
                      name="workMode"
                      value="<%= mode %>"
                      <%= formData.workMode === mode ? "checked" : "" %>
                      onclick="clearClientError('workMode')"
                    />
                    <span><%= mode %></span>
                  </label>
                <% }) %>
              </div>
              <small class="inline-error" id="workModeError"><%= fieldErrors.workMode || "" %></small>
            </div>
          </section>

          <section class="question-card">
            <div class="field-group">
              <label>
                Core Skills <span class="required-star">*</span>
              </label>
              <p class="field-help">Select the strengths you want to build on during the internship.</p>
              <div
                id="skillsGroup"
                class="option-grid skills-grid"
                style="<%= fieldErrors.skills ? 'border: 1px solid #f6aea9; border-radius: 10px; padding: 10px;' : '' %>"
              >
                <% skillOptions.forEach((skill) => { %>
                  <label class="option-card">
                    <input
                      type="checkbox"
                      name="skills"
                      value="<%= skill %>"
                      <%= formData.skills.includes(skill) ? "checked" : "" %>
                      onclick="clearClientError('skills')"
                    />
                    <span><%= skill %></span>
                  </label>
                <% }) %>
              </div>
              <small class="inline-error" id="skillsError"><%= fieldErrors.skills || "" %></small>
            </div>
          </section>

          <section class="question-card">
            <div class="field-group">
              <label for="portfolio">Portfolio / GitHub Link</label>
              <input
                type="url"
                id="portfolio"
                name="portfolio"
                placeholder="https://github.com/your-profile"
                value="<%= formData.portfolio %>"
                oninput="clearClientError('portfolio')"
                style="<%= fieldErrors.portfolio ? 'border-color: #b3261e; background-color: #fff8f8;' : '' %>"
              />
              <p
                id="portfolioHint"
                class="field-help"
                style="margin-top: 2px; color: #5b34a3;"
              >
                Optional, but recommended if you already have project work to share.
              </p>
              <small class="inline-error" id="portfolioError"><%= fieldErrors.portfolio || "" %></small>
            </div>
          </section>

          <section class="question-card">
            <div class="field-group">
              <label for="message">
                Why do you want to join this internship?
                <span class="required-star">*</span>
              </label>
              <p class="field-help">
                Tell us what you want to learn, what you can contribute, and
                how this internship fits your goals.
              </p>
              <textarea
                id="message"
                name="message"
                rows="5"
                maxlength="400"
                placeholder="Write at least 30 characters"
                oninput="updateMessageCount(this); clearClientError('message')"
                style="<%= fieldErrors.message ? 'border-color: #b3261e; background-color: #fff8f8;' : '' %>"
              ><%= formData.message %></textarea>
              <div class="counter-row">
                <small class="inline-error" id="messageError"><%= fieldErrors.message || "" %></small>
                <span
                  id="messageCount"
                  class="counter-badge"
                  style="background: #ede7f6; color: #5b34a3;"
                >
                  0 / 400
                </span>
              </div>
            </div>
          </section>

          <section class="question-card">
            <div class="field-group">
              <label class="consent-row">
                <input
                  type="checkbox"
                  name="newsletter"
                  value="yes"
                  <%= formData.newsletter ? "checked" : "" %>
                />
                <span>Send me updates about future Cognifyz learning opportunities.</span>
              </label>

              <label
                class="consent-row"
                id="consentRow"
                style="<%= fieldErrors.consent ? 'background: #fff4f4; border-color: #f6aea9;' : '' %>"
              >
                <input
                  type="checkbox"
                  name="consent"
                  value="yes"
                  <%= formData.consent ? "checked" : "" %>
                  onclick="clearClientError('consent')"
                />
                <span>
                  I confirm that the submitted information is accurate.
                  <span class="required-star">*</span>
                </span>
              </label>
              <small class="inline-error" id="consentError"><%= fieldErrors.consent || "" %></small>
            </div>
          </section>

          <div class="form-actions">
            <button type="submit">Validate and Submit</button>
            <p>Only validated submissions are kept in temporary server-side storage.</p>
          </div>
        </form>

      </section>
    </main>

    <script>
      function setStatus(message, isError) {
        const statusBox = document.getElementById("clientStatus");
        statusBox.style.display = "block";
        statusBox.textContent = message;
        statusBox.style.background = isError ? "#fce8e6" : "#eef7ee";
        statusBox.style.borderColor = isError ? "#f6aea9" : "#9ed49e";
        statusBox.style.color = isError ? "#b3261e" : "#1f5f1f";
      }

      function clearClientError(fieldName) {
        const errorNode = document.getElementById(fieldName + "Error");
        const field = document.getElementById(fieldName);

        if (errorNode && !errorNode.dataset.serverLocked) {
          errorNode.textContent = "";
        }

        if (field) {
          field.style.borderColor = "";
          field.style.backgroundColor = "";
        }

        if (fieldName === "workMode") {
          document.getElementById("workModeGroup").style.border = "";
          document.getElementById("workModeGroup").style.padding = "";
        }

        if (fieldName === "skills") {
          document.getElementById("skillsGroup").style.border = "";
          document.getElementById("skillsGroup").style.padding = "";
        }

        if (fieldName === "consent") {
          document.getElementById("consentRow").style.background = "";
          document.getElementById("consentRow").style.borderColor = "";
        }
      }

      function setFieldError(fieldName, message) {
        const errorNode = document.getElementById(fieldName + "Error");
        const field = document.getElementById(fieldName);

        if (errorNode) {
          errorNode.textContent = message;
          errorNode.dataset.serverLocked = "";
        }

        if (field) {
          field.style.borderColor = "#b3261e";
          field.style.backgroundColor = "#fff8f8";
        }

        if (fieldName === "workMode") {
          document.getElementById("workModeGroup").style.border = "1px solid #f6aea9";
          document.getElementById("workModeGroup").style.borderRadius = "10px";
          document.getElementById("workModeGroup").style.padding = "10px";
        }

        if (fieldName === "skills") {
          document.getElementById("skillsGroup").style.border = "1px solid #f6aea9";
          document.getElementById("skillsGroup").style.borderRadius = "10px";
          document.getElementById("skillsGroup").style.padding = "10px";
        }

        if (fieldName === "consent") {
          document.getElementById("consentRow").style.background = "#fff4f4";
          document.getElementById("consentRow").style.borderColor = "#f6aea9";
        }
      }

      function updateMessageCount(textarea) {
        const counter = document.getElementById("messageCount");
        const currentLength = textarea.value.trim().length;
        counter.textContent = currentLength + " / 400";
        counter.style.background = currentLength >= 30 ? "#e6f4ea" : "#ede7f6";
        counter.style.color = currentLength >= 30 ? "#1f5f1f" : "#5b34a3";
      }

      function updateTrackPreview(value) {
        const preview = document.getElementById("trackPreview");
        preview.textContent = value
          ? "Preferred track: " + value
          : "Preferred track: Awaiting selection";
      }

      function updatePortfolioHint(role) {
        const hint = document.getElementById("portfolioHint");
        if (role === "Intern" || role === "Working Professional") {
          hint.textContent = "Recommended for this role: share a portfolio, GitHub, or resume link.";
          return;
        }

        hint.textContent = "Optional, but recommended if you already have project work to share.";
      }

      function validateApplicationForm(form) {
        const fieldsToClear = [
          "fullName",
          "email",
          "phone",
          "role",
          "track",
          "workMode",
          "skills",
          "availability",
          "portfolio",
          "message",
          "consent"
        ];

        fieldsToClear.forEach(function(fieldName) {
          const errorNode = document.getElementById(fieldName + "Error");
          if (errorNode) {
            errorNode.textContent = "";
          }
          clearClientError(fieldName);
        });

        const fullName = form.fullName.value.trim();
        const email = form.email.value.trim();
        const phone = form.phone.value.trim();
        const role = form.role.value.trim();
        const track = form.track.value.trim();
        const availability = form.availability.value.trim();
        const portfolio = form.portfolio.value.trim();
        const message = form.message.value.trim();
        const workMode = form.querySelector('input[name="workMode"]:checked');
        const skills = form.querySelectorAll('input[name="skills"]:checked');
        const consent = form.querySelector('input[name="consent"]').checked;
        const errors = [];
        const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        const phonePattern = /^[+]?[\d\s-]{10,20}$/;

        function registerError(fieldName, message) {
          errors.push({ fieldName: fieldName, message: message });
          setFieldError(fieldName, message);
        }

        if (fullName.length < 3) {
          registerError("fullName", "Full name must be at least 3 characters long.");
        }

        if (!emailPattern.test(email)) {
          registerError("email", "Please enter a valid email address.");
        }

        if (!phonePattern.test(phone)) {
          registerError("phone", "Please enter a valid phone number.");
        }

        if (!role) {
          registerError("role", "Please select your current role.");
        }

        if (!track) {
          registerError("track", "Please choose your preferred track.");
        }

        if (!workMode) {
          registerError("workMode", "Please choose your preferred work mode.");
        }

        if (skills.length === 0) {
          registerError("skills", "Select at least one skill.");
        }

        if (!availability) {
          registerError("availability", "Please choose an availability date.");
        }

        if (portfolio && !/^https?:\/\//.test(portfolio)) {
          registerError("portfolio", "Portfolio link must start with http:// or https://.");
        }

        if (message.length < 30) {
          registerError("message", "Motivation message must be at least 30 characters long.");
        }

        if (!consent) {
          registerError("consent", "Please confirm that your information is accurate.");
        }

        if (errors.length > 0) {
          setStatus("Client-side validation found a few fields to fix before submission.", true);

          const firstField = document.getElementById(errors[0].fieldName);
          if (firstField) {
            firstField.focus();
          }

          return false;
        }

        setStatus("Client-side validation passed. Submitting to the server now.", false);
        return true;
      }

      updateMessageCount(document.getElementById("message"));
      updateTrackPreview(document.getElementById("track").value);
      updatePortfolioHint(document.getElementById("role").value);
    </script>
  </body>
</html>
