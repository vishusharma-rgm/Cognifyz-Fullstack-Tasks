<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand fw-semibold" href="/">Cognifyz Solutions</a>
        <div class="ms-auto">
          <a href="/" class="btn btn-outline-secondary btn-sm">Back to Home</a>
        </div>
      </div>
    </nav>

    <main>
      <section class="page-section border-bottom">
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-lg-8">
              <p class="section-label">About Company</p>
              <h1 class="page-title">About Cognifyz Solutions</h1>
              <p class="lead-text">
                Cognifyz Solutions is presented here as a sample company website
                for a realistic frontend internship task. The focus is on clean
                layouts, responsive structure, and practical implementation.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="page-section border-bottom">
        <div class="container">
          <div class="row gy-4">
            <div class="col-md-6">
              <h2 class="section-title">What we do</h2>
              <ul class="simple-list">
                <% aboutPoints.forEach((point) => { %>
                  <li><%= point %></li>
                <% }) %>
              </ul>
            </div>
            <div class="col-md-6">
              <h2 class="section-title">How we work</h2>
              <ul class="simple-list">
                <% aboutValues.forEach((value) => { %>
                  <li><%= value %></li>
                <% }) %>
              </ul>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer border-top">
      <div class="container py-3">
        <span>Cognifyz Solutions</span>
      </div>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
