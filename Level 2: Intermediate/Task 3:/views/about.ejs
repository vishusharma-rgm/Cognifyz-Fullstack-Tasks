<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="navbar navbar-expand-lg sticky-top navbar-shell">
        <div class="container nav-shell-inner">
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav nav-center">
              <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
              <li class="nav-item"><a class="nav-link active" href="/about">About</a></li>
              <li class="nav-item"><a class="nav-link" href="/services">Services</a></li>
              <li class="nav-item"><a class="nav-link" href="/process">Work</a></li>
              <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <section class="page-top-section">
        <div class="container">
          <div class="section-heading text-center" data-reveal="up">
            <p class="section-tag">About</p>
            <h1>About Cognifyz Solutions</h1>
            <p>
              A clean business-style about page with company details and animated stats.
            </p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="row g-4 align-items-center">
            <div class="col-lg-6" data-reveal="up">
              <div class="content-card about-story-card large-card">
                <p class="eyebrow-text">Our story</p>
                <h2 class="h3">Who we are</h2>
                <p>
                  Cognifyz Solutions is presented as a frontend-focused digital company
                  that helps businesses build responsive websites and clean user interfaces.
                </p>
                <ul class="content-list about-points">
                  <% aboutHighlights.forEach((item) => { %>
                    <li><%= item %></li>
                  <% }) %>
                </ul>
                <div class="about-actions">
                  <a href="/services" class="btn btn-primary">View Services</a>
                  <a href="/contact" class="btn btn-outline-primary">Talk to Our Team</a>
                </div>
              </div>
            </div>

            <div class="col-lg-6" data-reveal="up">
              <div class="about-visual-card">
                <div class="about-floating-badge float-slow">UI planning + delivery</div>
                <div class="about-dashboard-panel">
                  <div class="dashboard-window">
                    <div class="dashboard-bar"></div>
                    <div class="dashboard-grid">
                      <div class="dashboard-block dashboard-block-large"></div>
                      <div class="dashboard-block"></div>
                      <div class="dashboard-block"></div>
                      <div class="dashboard-block dashboard-block-accent"></div>
                    </div>
                  </div>
                </div>
                <div class="about-mini-card about-mini-card-left float-soft">
                  <span class="mini-card-icon">01</span>
                  <div>
                    <strong>Structured workflow</strong>
                    <p class="mb-0">Planning, design review, and polished frontend delivery.</p>
                  </div>
                </div>
                <div class="about-mini-card about-mini-card-right float-slow">
                  <span class="mini-card-icon">02</span>
                  <div>
                    <strong>User-first interface</strong>
                    <p class="mb-0">Readable layouts, responsive sections, and clean handoff.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-4 mt-2">
            <% aboutStats.forEach((stat) => { %>
              <div class="col-md-4" data-reveal="up">
                <div class="content-card stat-card about-stat-card">
                  <strong><%= stat.value %></strong>
                  <span><%= stat.label %></span>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="row g-4 mt-2">
            <div class="col-lg-4" data-reveal="up">
              <div class="content-card quick-info-card">
                <p class="eyebrow-text">Working style</p>
                <h3 class="h5">Clear communication</h3>
                <p class="mb-0">
                  We focus on simple design decisions, direct updates, and frontend work
                  that is easy for clients and developers to review.
                </p>
              </div>
            </div>
            <div class="col-lg-4" data-reveal="up">
              <div class="content-card quick-info-card">
                <p class="eyebrow-text">Project approach</p>
                <h3 class="h5">Build with purpose</h3>
                <p class="mb-0">
                  Every section is designed to support real business goals like clarity,
                  trust, and better user action on the page.
                </p>
              </div>
            </div>
            <div class="col-lg-4" data-reveal="up">
              <div class="content-card quick-info-card">
                <p class="eyebrow-text">Delivery focus</p>
                <h3 class="h5">Responsive by default</h3>
                <p class="mb-0">
                  Layouts are tested for desktop, tablet, and mobile so the experience
                  stays smooth across all common screen sizes.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-row">
        <div>
          <strong>Cognifyz Solutions</strong>
          <p class="mb-0">Frontend design and development for structured web projects.</p>
        </div>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/services">Services</a>
          <a href="/process">Work</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="/app.js"></script>
  </body>
</html>
