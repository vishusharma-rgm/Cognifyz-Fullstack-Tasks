<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="navbar navbar-expand-lg sticky-top navbar-shell">
        <div class="container nav-shell-inner">
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav nav-center">
              <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
              <li class="nav-item"><a class="nav-link active" href="/services">Services</a></li>
              <li class="nav-item"><a class="nav-link" href="/process">Work</a></li>
              <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <section class="page-top-section">
        <div class="container">
          <div class="section-heading text-center" data-reveal="up">
            <p class="section-tag">Services</p>
            <h1>Frontend services</h1>
            <p>
              A dedicated services page with a clean grid layout and subtle hover motion.
            </p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="row g-4 align-items-center mb-5">
            <div class="col-lg-6" data-reveal="up">
              <div class="content-card services-intro-card">
                <p class="eyebrow-text">What we offer</p>
                <h2 class="h3">Services built for practical business websites</h2>
                <p>
                  These services are arranged to help clients understand what gets delivered,
                  how the interface improves, and where the frontend adds value.
                </p>
                <div class="services-intro-points">
                  <span>Responsive layouts</span>
                  <span>Clear UI structure</span>
                  <span>Professional delivery</span>
                </div>
              </div>
            </div>
            <div class="col-lg-6" data-reveal="up">
              <div class="services-visual-card">
                <div class="services-floating-chip float-slow">Modern UI</div>
                <div class="services-visual-stack">
                  <div class="visual-screen visual-screen-main">
                    <div class="visual-screen-bar"></div>
                    <div class="visual-screen-content">
                      <div class="visual-line visual-line-large"></div>
                      <div class="visual-line"></div>
                      <div class="visual-row">
                        <div class="visual-box"></div>
                        <div class="visual-box visual-box-accent"></div>
                      </div>
                    </div>
                  </div>
                  <div class="visual-screen visual-screen-side float-soft">
                    <div class="visual-screen-bar"></div>
                    <div class="visual-screen-content">
                      <div class="visual-line visual-line-small"></div>
                      <div class="visual-line"></div>
                      <div class="visual-line"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-4">
            <% serviceCards.forEach((service, index) => { %>
              <div class="col-md-6 col-lg-4" data-reveal="up">
                <article class="content-card service-grid-card h-100">
                  <div class="service-card-top">
                    <span class="service-icon-badge"><%= `0${index + 1}`.slice(-2) %></span>
                    <span class="service-chip"><%= index % 2 === 0 ? 'Design + Build' : 'UI Support' %></span>
                  </div>
                  <h2 class="h5"><%= service.title %></h2>
                  <p><%= service.description %></p>
                  <div class="service-card-footer">
                    <span>Responsive output</span>
                    <a href="/contact">Discuss service</a>
                  </div>
                </article>
              </div>
            <% }) %>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-row">
        <div>
          <strong>Cognifyz Solutions</strong>
          <p class="mb-0">Frontend design and development for structured web projects.</p>
        </div>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/process">Work</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="/app.js"></script>
  </body>
</html>
