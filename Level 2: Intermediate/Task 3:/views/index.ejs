<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand fw-semibold" href="/">Cognifyz Solutions</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#mainNav"
          aria-controls="mainNav"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link" href="#top">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
            <li class="nav-item"><a class="nav-link" href="#process">Work Process</a></li>
            <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
            <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <main>
      <section id="top" class="page-section border-bottom">
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
              <p class="section-label">Level 2 Intermediate Task 3</p>
              <h1 class="page-title">Frontend website layout for a small service company</h1>
              <div class="d-flex flex-column flex-sm-row justify-content-center gap-2 mt-4">
                <a href="#services" class="btn btn-primary">View Services</a>
                <a href="/about" class="btn btn-outline-secondary">About Company</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="page-section border-bottom timeline-section">
        <div class="container">
          <div class="row justify-content-center mb-4">
            <div class="col-lg-8 text-center">
              <p class="section-label">Services</p>
              <h2 class="section-title">Our frontend development services</h2>
              <p class="section-text">
                These service steps are shown in a vertical timeline to make the
                section more structured and visually clear.
              </p>
            </div>
          </div>

          <div class="timeline-wrapper">
            <div class="timeline-line"></div>
            <div class="timeline-line-fill"></div>

            <% serviceCards.forEach((card, index) => { const isLeft = index % 2 === 0; %>
              <div class="timeline-item <%= isLeft ? 'timeline-left' : 'timeline-right' %>">
                <div class="timeline-step"><%= card.badge %></div>
                <div class="timeline-card reveal-card">
                  <h3 class="h5 mb-2"><%= card.title %></h3>
                  <p class="mb-0"><%= card.description %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <section id="process" class="page-section border-bottom timeline-section">
        <div class="container">
          <div class="row justify-content-center mb-4">
            <div class="col-lg-8 text-center">
              <p class="section-label">Work Process</p>
              <h2 class="section-title">How we complete a frontend project</h2>
              <p class="section-text">
                A simple workflow timeline showing the main stages from planning
                to delivery.
              </p>
            </div>
          </div>

          <div class="timeline-wrapper">
            <div class="timeline-line"></div>
            <div class="timeline-line-fill"></div>

            <% processSteps.forEach((step, index) => { const isLeft = index % 2 === 0; %>
              <div class="timeline-item <%= isLeft ? 'timeline-left' : 'timeline-right' %>">
                <div class="timeline-step">0<%= index + 1 %></div>
                <div class="timeline-card reveal-card">
                  <h3 class="h5 mb-2"><%= step.title %></h3>
                  <p class="mb-0"><%= step.description %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <section id="contact" class="page-section">
        <div class="container">
          <div class="row gy-4">
            <div class="col-lg-5">
              <h2 class="section-title">Contact</h2>
              <p class="section-text">
                You can use this section to collect client inquiries or project requests.
              </p>
              <p class="mb-0"><strong>Email:</strong> hello@cognifyzsolutions.com</p>
              <p class="mb-0"><strong>Phone:</strong> +91 98765 43210</p>
            </div>
            <div class="col-lg-7">
              <form class="contact-form">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label" for="contactName">Name</label>
                    <input id="contactName" type="text" class="form-control" placeholder="Enter your name" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="contactEmail">Email</label>
                    <input id="contactEmail" type="email" class="form-control" placeholder="Enter your email" />
                  </div>
                  <div class="col-12">
                    <label class="form-label" for="contactMessage">Message</label>
                    <textarea
                      id="contactMessage"
                      class="form-control"
                      rows="4"
                      placeholder="Write your message"
                    ></textarea>
                  </div>
                  <div class="col-12">
                    <button type="button" class="btn btn-primary">Send Message</button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer border-top">
      <div class="container d-flex flex-column flex-md-row justify-content-between gap-2 py-3">
        <span>Cognifyz Solutions</span>
        <span>Built with Express, EJS, Bootstrap, and custom CSS</span>
      </div>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="/app.js"></script>
  </body>
</html>
