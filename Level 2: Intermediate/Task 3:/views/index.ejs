<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="navbar navbar-expand-lg sticky-top navbar-shell">
        <div class="container">
          <a class="navbar-brand brand-name" href="/">Cognifyz Solutions</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav nav-center mx-auto">
              <li class="nav-item"><a class="nav-link active" href="/">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
              <li class="nav-item"><a class="nav-link" href="/services">Services</a></li>
              <li class="nav-item"><a class="nav-link" href="/process">Work</a></li>
              <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero-section">
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-lg-8 text-center" data-reveal="up">
              <p class="section-tag">Level 2 Intermediate Task 3</p>
              <h1 class="hero-title">Modern frontend solutions for practical business websites</h1>
              <p class="hero-text">
                A clean multi-page website built with Bootstrap, custom CSS, and smooth
                scroll-based animations. The design stays premium, structured, and
                realistic for an internship-level frontend project.
              </p>
              <div class="hero-actions justify-content-center">
                <a href="/services" class="btn btn-primary">Explore Services</a>
                <a href="/contact" class="btn btn-outline-primary">Start a Project</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-heading text-center" data-reveal="up">
            <p class="section-tag">Features</p>
            <h2>What this project demonstrates</h2>
            <p>
              The homepage includes a practical mix of service highlights, process explanation,
              testimonials, and contact flow.
            </p>
          </div>

          <div class="row g-4">
            <% featureCards.forEach((card) => { %>
              <div class="col-md-6 col-lg-4" data-reveal="up">
                <article class="content-card h-100">
                  <h3 class="h5"><%= card.title %></h3>
                  <p class="mb-0"><%= card.description %></p>
                </article>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="content-section process-preview">
        <div class="container">
          <div class="section-heading text-center" data-reveal="up">
            <p class="section-tag">Process</p>
            <h2>How a frontend project moves forward</h2>
            <p>
              The work process is shown using an aligned timeline with minimal reveal animation.
            </p>
          </div>

          <div class="timeline-wrapper" data-reveal="up">
            <div class="timeline-line"></div>
            <div class="timeline-line-fill"></div>

            <% processSteps.forEach((step, index) => { const isLeft = index % 2 === 0; %>
              <div class="timeline-item <%= isLeft ? 'timeline-left' : 'timeline-right' %>">
                <div class="timeline-dot"><%= step.step %></div>
                <article class="timeline-card" data-reveal="up">
                  <h3 class="h5 mb-2"><%= step.title %></h3>
                  <p class="mb-0"><%= step.description %></p>
                </article>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-heading text-center" data-reveal="up">
            <p class="section-tag">Feedback</p>
            <h2>Client feedback</h2>
            <p>Feedback shared by teams after project delivery and frontend review.</p>
          </div>

          <div class="row g-4 align-items-start">
            <div class="col-lg-4" data-reveal="up">
              <div class="content-card testimonial-overview h-100">
                <h3 class="h5 mb-3">Delivery summary</h3>
                <p>
                  This section presents sample client comments in a more structured
                  company-style format instead of plain review cards.
                </p>
                <ul class="content-list mb-0">
                  <li>Clear page structure and alignment</li>
                  <li>Responsive layout across screen sizes</li>
                  <li>Professional and easy-to-review interface</li>
                </ul>
              </div>
            </div>

            <div class="col-lg-8">
              <div class="row g-4">
                <% testimonials.forEach((item) => { %>
                  <div class="col-md-6" data-reveal="up">
                    <article class="content-card testimonial-card h-100">
                      <p class="testimonial-project"><%= item.project %></p>
                      <p class="testimonial-text">"<%= item.quote %>"</p>
                      <div class="testimonial-meta">
                        <strong><%= item.author %></strong>
                        <span><%= item.role %></span>
                        <small><%= item.company %></small>
                      </div>
                    </article>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-row">
        <div>
          <strong>Cognifyz Solutions</strong>
          <p class="mb-0">Frontend design and development for structured web projects.</p>
        </div>
        <div class="footer-links">
          <a href="/about">About</a>
          <a href="/services">Services</a>
          <a href="/process">Work</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="/app.js"></script>
  </body>
</html>
