<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="navbar navbar-expand-lg sticky-top navbar-shell">
        <div class="container nav-shell-inner">
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNav"
            aria-controls="mainNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav nav-center">
              <li class="nav-item"><a class="nav-link active" href="/">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
              <li class="nav-item"><a class="nav-link" href="/services">Services</a></li>
              <li class="nav-item"><a class="nav-link" href="/process">Work</a></li>
              <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero-section">
        <span class="hero-orb hero-orb-one"></span>
        <span class="hero-orb hero-orb-two"></span>
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-lg-8 text-center hero-parallax" data-reveal="up">
              <p class="section-tag">Level 2 Intermediate Task 3</p>
              <h1 class="hero-title">Modern frontend solutions for practical business websites</h1>
              <p class="hero-text">
                A clean multi-page website built with Bootstrap, custom CSS, and smooth
                scroll-based animations. The design stays premium, structured, and
                realistic for an internship-level frontend project.
              </p>
              <div class="hero-actions justify-content-center">
                <a href="/services" class="btn btn-primary">Explore Services</a>
                <a href="/contact" class="btn btn-outline-primary">Start a Project</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-heading text-center" data-reveal="up">
            <p class="section-tag">Features</p>
            <h2>What this project demonstrates</h2>
            <p>
              The homepage includes a practical mix of service highlights, process explanation,
              testimonials, and contact flow.
            </p>
          </div>

          <div class="row g-4">
            <% featureCards.forEach((card) => { %>
              <div class="col-md-6 col-lg-4" data-reveal="up">
                <article class="content-card h-100">
                  <h3 class="h5"><%= card.title %></h3>
                  <p class="mb-0"><%= card.description %></p>
                </article>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="content-section process-preview">
        <div class="container">
          <div class="section-heading text-center" data-reveal="up">
            <p class="section-tag">Process</p>
            <h2>How a frontend project moves forward</h2>
            <p>
              The work process is shown using an aligned timeline with minimal reveal animation.
            </p>
          </div>

          <div class="timeline-wrapper" data-reveal="up">
            <div class="timeline-line"></div>
            <div class="timeline-line-fill"></div>

            <% processSteps.forEach((step, index) => { const isLeft = index % 2 === 0; %>
              <div class="timeline-item <%= isLeft ? 'timeline-left' : 'timeline-right' %>">
                <div class="timeline-dot"><%= step.step %></div>
                <article class="timeline-card" data-reveal="up">
                  <h3 class="h5 mb-2"><%= step.title %></h3>
                  <p class="mb-0"><%= step.description %></p>
                </article>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-heading text-center" data-reveal="up">
            <p class="section-tag">Feedback</p>
            <h2>Client feedback</h2>
            <p>Feedback shared by teams after project delivery and frontend review.</p>
          </div>

          <div class="feedback-showcase" data-reveal="up">
            <div class="feedback-summary-bar">
              <div class="feedback-summary-copy">
                <p class="feedback-kicker">Client feedback</p>
                <h3 class="feedback-summary-title">Structured reviews from recent frontend delivery</h3>
              </div>

              <div class="feedback-summary-metrics">
                <div class="feedback-metric">
                  <strong>4.9/5</strong>
                  <span>average rating</span>
                </div>
                <div class="feedback-metric">
                  <strong><%= testimonials.length %></strong>
                  <span>verified reviews</span>
                </div>
                <div class="feedback-metric">
                  <strong>100%</strong>
                  <span>responsive checked</span>
                </div>
              </div>
            </div>

            <div class="row g-3">
              <% testimonials.forEach((item) => { const initials = item.author.split(" ").map((part) => part[0]).join("").slice(0, 2).toUpperCase(); %>
                <div class="col-lg-4 col-md-6">
                  <article
                    class="content-card testimonial-card h-100"
                    tabindex="0"
                    role="button"
                    aria-label="Open feedback from <%= item.author %>"
                    data-feedback-trigger
                    data-feedback-author="<%= item.author %>"
                    data-feedback-role="<%= item.role %>"
                    data-feedback-company="<%= item.company %>"
                    data-feedback-project="<%= item.project %>"
                    data-feedback-quote="<%= item.quote %>"
                    data-feedback-focus="<%= item.focus %>"
                    data-feedback-outcome="<%= item.outcome %>"
                  >
                    <div class="testimonial-topline">
                      <div class="testimonial-avatar"><%= initials %></div>
                      <div class="testimonial-identity">
                        <strong><%= item.author %></strong>
                        <span><%= item.role %></span>
                      </div>
                      <span class="testimonial-score">5.0</span>
                    </div>

                    <p class="testimonial-text testimonial-text-preview">"<%= item.quote %>"</p>

                    <div class="testimonial-footer">
                      <div class="testimonial-company">
                        <small>Company</small>
                        <span><%= item.company %></span>
                      </div>
                      <p class="testimonial-project mb-0"><%= item.project %></p>
                      <span class="testimonial-open-link">Click to open full feedback</span>
                    </div>
                  </article>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </section>

      <div class="modal fade feedback-modal" id="feedbackModal" tabindex="-1" aria-labelledby="feedbackModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content feedback-modal-content">
            <div class="modal-header feedback-modal-header">
              <div>
                <p class="feedback-kicker mb-2">Client feedback</p>
                <h3 class="modal-title h4 mb-0" id="feedbackModalLabel">Feedback details</h3>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body feedback-modal-body">
              <div class="feedback-modal-meta">
                <div>
                  <small>Reviewer</small>
                  <strong id="feedbackModalAuthor">Client Name</strong>
                  <span id="feedbackModalRole">Role</span>
                </div>
                <div>
                  <small>Project</small>
                  <strong id="feedbackModalProject">Project name</strong>
                  <span id="feedbackModalCompany">Company</span>
                </div>
              </div>

              <blockquote class="feedback-modal-quote" id="feedbackModalQuote">
                Full feedback will appear here.
              </blockquote>

              <div class="feedback-modal-grid">
                <div class="feedback-modal-card">
                  <small>Focus area</small>
                  <p id="feedbackModalFocus" class="mb-0">Feedback focus area</p>
                </div>
                <div class="feedback-modal-card">
                  <small>Outcome</small>
                  <p id="feedbackModalOutcome" class="mb-0">Feedback outcome</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-row">
        <div>
          <strong>Cognifyz Solutions</strong>
          <p class="mb-0">Frontend design and development for structured web projects.</p>
        </div>
        <div class="footer-links">
          <a href="/about">About</a>
          <a href="/services">Services</a>
          <a href="/process">Work</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="/app.js"></script>
  </body>
</html>
